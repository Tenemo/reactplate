{
    "compilerOptions": {
        "baseUrl": "./src/",
        "jsx": "react",
        "target": "ES2017",
        "module": "esnext",
        "moduleResolution": "bundler",
        "removeComments": true,
        "declaration": false,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strict": true,
        "sourceMap": true,
        "allowJs": true,
        "noEmit": true,
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "include": [
        "src/**/*",
        "config/**/*",
        "temp/**/*",
        "eslint.config.js",
        ".babelrc.cjs"
    ],
    "exclude": ["**/*.snap"]
}
