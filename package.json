{
    "name": "reactplate",
    "version": "1.0.3",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "MIT",
    "description": "Flat ESLint | React, Redux, Jest & 🔥 reload | TypeScript parsed with Babel 7",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/reactplate.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/reactplate/issues"
    },
    "homepage": "https://github.com/Tenemo/reactplate#readme",
    "scripts": {
        "start": "cross-env NODE_ENV=development npm run open:src",
        "prebuild": "npm run lint && npm run tsc && npm test && npm run cleanDist",
        "build": "cross-env NODE_ENV=production webpack --config config/webpack/webpack.prod.babel.ts",
        "build:analyze": "npm run cleanDist && cross-env NODE_ENV=production ANALYZE=true webpack --config config/webpack/webpack.prod.babel.ts",
        "build:skip": "npm run cleanDist && cross-env NODE_ENV=production webpack --config config/webpack/webpack.prod.babel.ts",
        "cleanDist": "rimraf ./dist && mkdir dist",
        "eslint": "eslint . -c eslint.config.js",
        "eslint:fix": "eslint . --fix -c eslint.config.js",
        "stylelint": "stylelint **/*.scss **/*.css",
        "lint": "npm run eslint && npm run stylelint",
        "open:dist": "http-server dist --port 4000 --proxy http://localhost:4000?",
        "open:src": "cross-env PORT=3000 webpack serve --config config/webpack/webpack.dev.babel.ts",
        "postinstall": "husky install",
        "tsc": "tsc",
        "temp": "ts-node temp/script",
        "test": "cross-env NODE_ENV=test jest",
        "test:update": "npm run test -- --update",
        "test:coverage": "npm run test -- --coverage",
        "test:watch": "npm run test -- --watch",
        "prepare": "husky"
    },
    "browserslist": [
        "> 0.5%",
        "not dead",
        "not IE > 0",
        "not op_mini all"
    ],
    "engines": {
        "node": ">=22.13.0 <23"
    },
    "type": "module",
    "dependencies": {
        "@babel/runtime-corejs3": "^7.29.2",
        "@sentry/react": "^10.46.0",
        "axios": "^1.14.0",
        "core-js": "^3.49.0",
        "date-fns": "^4.1.0",
        "history": "^5.3.0",
        "normalize.css": "^8.0.1",
        "npm": "^11.12.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-helmet-async": "^3.0.0",
        "react-redux": "^9.2.0",
        "react-router": "^7.13.2",
        "react-router-dom": "^7.13.2",
        "redux": "^5.0.1",
        "redux-first-history": "^5.2.0",
        "redux-thunk": "^3.1.0",
        "reselect": "^5.1.1"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/node": "^7.29.0",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@eslint/compat": "^2.0.3",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
        "@redux-devtools/extension": "^4.0.0",
        "@teamsupercell/typings-for-css-modules-loader": "^2.5.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/circular-dependency-plugin": "^5.0.8",
        "@types/core-js": "^2.5.8",
        "@types/eslint": "^9.6.1",
        "@types/eslint-plugin-prettier": "^3.1.3",
        "@types/html-webpack-plugin": "^3.2.9",
        "@types/http-server": "^0.12.4",
        "@types/ip": "^1.1.3",
        "@types/jest": "^30.0.0",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^25.5.0",
        "@types/npm": "^7.19.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-redux": "^7.1.34",
        "@types/redux-logger": "^3.0.13",
        "@types/webpack-bundle-analyzer": "^4.7.0",
        "@types/webpack-env": "^1.18.8",
        "@typescript-eslint/eslint-plugin": "8.57.3-alpha.3",
        "@typescript-eslint/parser": "8.57.3-alpha.3",
        "autoprefixer": "^10.4.27",
        "babel-jest": "^30.3.0",
        "babel-loader": "^10.1.1",
        "babel-plugin-module-resolver": "^5.0.3",
        "circular-dependency-plugin": "^5.2.2",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.1.0-canary-9627b5a1-20260327",
        "globals": "^17.4.0",
        "html-webpack-plugin": "^5.6.6",
        "http-server": "^14.1.1",
        "husky": "^9.1.7",
        "immutable": "^5.1.5",
        "ip": "^2.0.1",
        "jest": "^30.3.0",
        "jest-cli": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jsdom": "^29.0.1",
        "mini-css-extract-plugin": "^2.10.2",
        "postcss": "^8.5.8",
        "postcss-flexbugs-fixes": "^5.0.2",
        "postcss-html": "^1.8.1",
        "postcss-loader": "^8.2.1",
        "prettier": "^3.8.1",
        "prettier-eslint": "^16.4.2",
        "prettier-stylelint": "^0.4.2",
        "react-refresh": "^0.18.0",
        "redux-logger": "^3.0.6",
        "rimraf": "^6.1.3",
        "sass": "^1.98.0",
        "sass-loader": "^16.0.7",
        "style-loader": "^4.0.0",
        "stylelint": "^17.6.0",
        "stylelint-config-recommended": "^18.0.0",
        "stylelint-config-recommended-scss": "^17.0.0",
        "stylelint-scss": "^7.0.0",
        "typescript": "^6.0.2",
        "webpack": "^5.105.4",
        "webpack-bundle-analyzer": "^5.3.0",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.3",
        "webpack-merge": "^6.0.1"
    },
    "jest": {
        "collectCoverageFrom": [
            "<rootDir>/src/**/*{js,jsx,ts,tsx}"
        ],
        "coveragePathIgnorePatterns": [
            "<rootDir>/src/index.tsx"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/config/testSetup.ts"
        ],
        "moduleNameMapper": {
            "^@redux-devtools/extension$": "<rootDir>/config/reduxDevtoolsExtension.ts",
            "\\.(jpg|jpeg|png|gif|ico|woff|woff2|svg|ttf|eot)$": "<rootDir>/config/assetsTransformer.ts",
            "^.+\\.(css|scss)$": "<rootDir>/config/assetsTransformer.ts"
        },
        "testEnvironment": "jsdom"
    }
}
